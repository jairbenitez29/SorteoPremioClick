# Copia este archivo como .env y rellena los valores (los mismos que en Vercel)
DB_HOST=172.99.21.54
DB_PORT=3306
DB_USER=premioclick_premioclick_user
DB_PASSWORD=MAMATEAMO123.
DB_NAME=premioclick_premioclick_db
DB_TYPE=mysql

# PayPal (obtener en https://developer.paypal.com → Apps & Credentials)
# Sandbox = pruebas | Live = producción. Las credenciales deben coincidir con el modo.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Conversión CLP → USD para PayPal. Ej: 1000 = 1000 CLP = 1 USD (50 CLP = 0.05 USD)
# Si en PayPal ves 1 USD cuando el ticket vale 50 CLP, revisa que sorteo.precio_ticket y tickets.precio sean 50 en la BD.
TASA_CLP_USD=1000
